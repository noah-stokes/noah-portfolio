---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Noah Stokes | AI Portfolio",
  description = "A generated-style portfolio for Noah Stokes, Computer Science student at the University of Waterloo.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#060609" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <title>{title}</title>
    <noscript>
      <style>
        .ai-intro {
          display: none !important;
        }

        .generated-shell {
          opacity: 1 !important;
          transform: none !important;
        }
      </style>
    </noscript>
  </head>
  <body>
    <slot />
  </body>
</html>
