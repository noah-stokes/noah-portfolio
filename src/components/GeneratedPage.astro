---
import ContactBlock from "./ContactBlock.astro";
import ExperienceTimeline from "./ExperienceTimeline.astro";
import GeneratedHero from "./GeneratedHero.astro";
import ProjectGrid from "./ProjectGrid.astro";
import TechProfile from "./TechProfile.astro";
import { focusItems } from "../data/profile";
---

<main class="generated-shell" id="top">
  <GeneratedHero />
  <ProjectGrid />
  <TechProfile />
  <ExperienceTimeline />

  <section class="section focus-section" aria-labelledby="focus-title">
    <div class="section-heading">
      <p class="section-kicker">Current Focus</p>
      <h2 id="focus-title">Active build direction</h2>
    </div>

    <div class="focus-grid">
      {
        focusItems.map((item, index) => (
          <article class="focus-item">
            <span class="focus-item__index">{String(index + 1).padStart(2, "0")}</span>
            <p>{item}</p>
          </article>
        ))
      }
    </div>
  </section>

  <ContactBlock />
</main>
