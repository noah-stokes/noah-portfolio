---
import { timeline } from "../data/profile";
---

<section class="section" aria-labelledby="timeline-title">
  <div class="section-heading">
    <p class="section-kicker">Experience Timeline</p>
    <h2 id="timeline-title">Signal from current trajectory</h2>
  </div>

  <div class="timeline">
    {
      timeline.map((item) => (
        <article class="timeline-item">
          <span class="timeline-item__period">{item.period}</span>
          <div>
            <p class="timeline-item__meta">{item.meta}</p>
            <h3>{item.title}</h3>
            <p>{item.description}</p>
          </div>
        </article>
      ))
    }
  </div>
</section>
